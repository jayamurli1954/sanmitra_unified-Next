APP_NAME=SanMitra Unified Backend
APP_VERSION=0.1.0
ENVIRONMENT=development

MONGODB_URI=mongodb://localhost:27017/sanmitra
MONGO_DB_NAME=sanmitra
MONGO_SERVER_SELECTION_TIMEOUT_MS=2000
MONGO_CONNECT_TIMEOUT_MS=2000
MONGO_SOCKET_TIMEOUT_MS=5000
POSTGRES_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/sanmitra
PG_CONNECT_TIMEOUT_SECONDS=5
PG_POOL_SIZE=8
PG_MAX_OVERFLOW=0
PG_POOL_TIMEOUT_SECONDS=5
PG_POOL_RECYCLE_SECONDS=300
PG_AUTO_CREATE_TABLES=true

JWT_SECRET=replace-this-with-a-long-random-string-minimum-64-characters
OTP_PEPPER=replace-this-with-a-different-long-random-string-minimum-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

ALLOWED_ORIGINS=*

# Frontend app identification for multi-frontend single-backend architecture
DEFAULT_APP_KEY=mandirmitra
ALLOWED_APP_KEYS=mandirmitra,gruhamitra,mitrabooks,legalmitra,investmitra

GOOGLE_OAUTH_CLIENT_IDS=
AUTH_PUBLIC_BASE_URL=http://localhost:3200
AUTH_ACTIVATION_TOKEN_TTL_MINUTES=60
AUTH_RESET_TOKEN_TTL_MINUTES=30
AUTH_EMAIL_DEBUG_RETURN_LINK=true

# Unified SMTP email (used by auth flows + onboarding approvals)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=no-reply@sanmitra.local
SMTP_FROM_NAME=SanMitra
# Mobile OTP login
MOBILE_OTP_ENABLED=true
MOBILE_OTP_LENGTH=6
MOBILE_OTP_TTL_SECONDS=300
MOBILE_OTP_MAX_ATTEMPTS=5
MOBILE_OTP_RESEND_COOLDOWN_SECONDS=30
MOBILE_OTP_DEBUG_RETURN_CODE=false
MOBILE_OTP_PROVIDER=none
MOBILE_OTP_MESSAGE_TEMPLATE=Your SanMitra OTP is {otp}. Valid for {ttl_minutes} minutes.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Token required in X-Onboarding-Token header on the public first-login onboarding endpoint.
# If left empty, the endpoint is open (dev/demo convenience); set in production.
MANDIR_ONBOARDING_SECRET=

# Super admin bootstrap (recommended in local/dev; disable in production unless intended)
SUPER_ADMIN_BOOTSTRAP=true
SUPER_ADMIN_EMAIL=superadmin@sanmitra.local
SUPER_ADMIN_PASSWORD=superadmin123
SUPER_ADMIN_FULL_NAME=SanMitra Super Admin
SUPER_ADMIN_TENANT_ID=seed-tenant-1

# Demo Mandir bootstrap (non-production convenience seed)
DEMO_MANDIR_BOOTSTRAP=true
DEMO_MANDIR_TENANT_ID=demo-mandir-tenant
DEMO_MANDIR_TEMPLE_NAME=Demo Temple
DEMO_MANDIR_TRUST_NAME=Demo Temple Trust
DEMO_MANDIR_TEMPLE_ADDRESS=Demo Temple Address
DEMO_MANDIR_TEMPLE_CONTACT=+91-9000000000
DEMO_MANDIR_TEMPLE_EMAIL=temple.demo@sanmitra.local
DEMO_MANDIR_ADMIN_FULL_NAME=Demo Temple Admin
DEMO_MANDIR_ADMIN_EMAIL=demo.admin@sanmitra.local
DEMO_MANDIR_ADMIN_PASSWORD=DemoTemple@123
DEMO_MANDIR_ADMIN_PHONE=+91-9000000001

# Phase-2 RAG embedding provider
# options: hash | gemini | sentence_transformers | openai
RAG_EMBEDDING_PROVIDER=hash
RAG_EMBEDDING_HASH_DIM=256
RAG_EMBEDDING_ST_MODEL=all-MiniLM-L6-v2
RAG_EMBEDDING_OPENAI_URL=
RAG_EMBEDDING_OPENAI_MODEL=text-embedding-3-small
RAG_EMBEDDING_OPENAI_API_KEY=

# Gemini embeddings (can reuse the same Gemini API key/project)
GEMINI_API_KEY=
RAG_GEMINI_EMBED_MODEL=gemini-embedding-001
RAG_GEMINI_EMBED_DIM=768
RAG_GEMINI_TASK_TYPE=RETRIEVAL_DOCUMENT
RAG_GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Hybrid legal research behavior
LEGAL_HYBRID_AI_FALLBACK_ENABLED=true
LEGAL_RAG_ENABLED=true
LEGAL_FALLBACK_GEMINI_MODEL=gemini-2.5-flash
LEGAL_FALLBACK_MAX_TOKENS=1800

# Official form bank (LegalMitra upload constraints)
LEGAL_OFFICIAL_FORM_MAX_UPLOAD_MB=20
LEGAL_OFFICIAL_FORM_MAX_PAGES=80
LEGAL_OFFICIAL_FORM_MIN_SUGGESTED_LABELS=3

# Auto-sync queue hooks (triggered when RAG confidence is low)
RAG_AUTO_SYNC_ENABLED=true

# Legal RAG sync worker (continuous queue processor)
LEGAL_SYNC_WORKER_ENABLED=true
LEGAL_SYNC_WORKER_POLL_SECONDS=60
LEGAL_SYNC_WORKER_BATCH_SIZE=5
LEGAL_SYNC_WORKER_MAX_ATTEMPTS=4
LEGAL_SYNC_WORKER_LOCK_TIMEOUT_SECONDS=600
LEGAL_SYNC_WORKER_MAX_SOURCES_PER_JOB=8
LEGAL_SYNC_WORKER_HTTP_TIMEOUT_SECONDS=15

# Tavily/Web search
TAVILY_API_KEY=
ENABLE_WEB_SEARCH=true
WEB_SEARCH_TIMEOUT_SECONDS=5


