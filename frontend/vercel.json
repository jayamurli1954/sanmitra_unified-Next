{
  "routes": [
    {
      "src": "^/$",
      "dest": "/mitrabooks-erp/index.html"
    },
    {
      "src": "^/index\\.html$",
      "dest": "/mitrabooks-erp/index.html"
    },
    {
      "src": "^/manifest\\.webmanifest$",
      "dest": "/mitrabooks-erp/manifest.webmanifest"
    },
    {
      "src": "^/api/health$",
      "dest": "https://sanmitra-unified-next-staging-sg.onrender.com/health"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "https://sanmitra-unified-next-staging-sg.onrender.com/api/$1"
    },
    {
      "src": "^/app\\.js$",
      "dest": "/mitrabooks-erp/app.js"
    },
    {
      "handle": "filesystem"
    }
  ]
}
