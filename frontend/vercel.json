{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "create-react-app",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "redirects": [
    {
      "source": "/gruhamitra",
      "destination": "/gruhamitra/",
      "permanent": false
    },
    {
      "source": "/mitrabooks-erp",
      "destination": "/mitrabooks-erp/",
      "permanent": false
    },
    {
      "source": "/legalmitra",
      "destination": "/legalmitra/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "www.legalmitra.sanmitratech.in" }
      ],
      "destination": "/legalmitra/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "legalmitra.sanmitratech.in" }
      ],
      "destination": "/legalmitra/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "www.mitrabooks.sanmitratech.in" }
      ],
      "destination": "/mitrabooks-erp/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "mitrabooks.sanmitratech.in" }
      ],
      "destination": "/mitrabooks-erp/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "staging.mitrabooks.sanmitratech.in" }
      ],
      "destination": "/mitrabooks-erp/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "mitrabooks-erp-staging.vercel.app" }
      ],
      "destination": "/mitrabooks-erp/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "www.gruhamitra.sanmitratech.in" }
      ],
      "destination": "/gruhamitra/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "gruhamitra.sanmitratech.in" }
      ],
      "destination": "/gruhamitra/",
      "permanent": false
    },
    {
      "source": "/mandir-public",
      "destination": "/pay",
      "permanent": false
    },
    {
      "source": "/mandir-public/",
      "destination": "/pay",
      "permanent": false
    },
    {
      "source": "/mandir-public/:path*",
      "destination": "/pay",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sanmitra-unified-next-staging-sg.onrender.com/api/:path*"
    },
    {
      "source": "/gruhamitra/:path((?!.*\\.).*)",
      "destination": "/gruhamitra/index.html"
    },
    {
      "source": "/legalmitra/:path((?!.*\\.).*)",
      "destination": "/legalmitra/index.html"
    },
    {
      "source": "/mitrabooks-erp/login",
      "destination": "/mitrabooks-erp/login.html"
    },
    {
      "source": "/mitrabooks-erp/:path((?!.*\\.).*)",
      "destination": "/mitrabooks-erp/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/mitrabooks-erp/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/mitrabooks-erp/login.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/legalmitra/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/legalmitra/app.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/mitrabooks-erp/app.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/mitrabooks-erp/index.css",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/sw-register.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/:path*",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://accounts.google.com/gsi/client; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.onrender.com https://api.postalpincode.in https://accounts.google.com; frame-src https://accounts.google.com; frame-ancestors 'none';" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/static/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
